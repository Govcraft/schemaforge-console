{
  "name": "@schemaforge/client",
  "version": "0.1.0",
  "description": "Framework-agnostic SchemaForge wire client + schema normalization. No React, router, or query library.",
  "license": "(MIT OR Apache-2.0)",
  "author": "Roland Rodriguez <roland@govcraft.ai>",
  "type": "module",
  "sideEffects": false,
  "files": ["dist"],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "tsup": "^8.3.0",
    "typescript": "^5.6.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
