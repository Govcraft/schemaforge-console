{
  "name": "@schemaforge/react",
  "version": "0.1.0",
  "description": "Schema-agnostic React components + headless hooks for SchemaForge. Router-agnostic; styled via tokens.",
  "license": "(MIT OR Apache-2.0)",
  "author": "Roland Rodriguez <roland@govcraft.ai>",
  "type": "module",
  "sideEffects": ["**/*.css"],
  "files": ["dist", "src/styles.css"],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./styles.css": "./src/styles.css"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@schemaforge/client": "workspace:*"
  },
  "peerDependencies": {
    "@tanstack/react-query": ">=5",
    "react": ">=18",
    "react-dom": ">=18"
  },
  "devDependencies": {
    "@tanstack/react-query": "^5.59.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "tsup": "^8.3.0",
    "typescript": "^5.6.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
